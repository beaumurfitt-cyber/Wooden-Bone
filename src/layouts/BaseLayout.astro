---
import '../styles/global.css';
import TrackingScript from '../components/TrackingScript.astro';
import { site } from '../data/site';
const {title,description} = Astro.props;
---
<html lang="en-AU"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/><title>{title}</title><meta name="description" content={description}/><meta property="og:title" content={title}/><meta property="og:description" content={description}/><meta property="og:type" content="website"/><TrackingScript />
<script type="application/ld+json" set:html={JSON.stringify({'@context':'https://schema.org','@type':'HomeAndConstructionBusiness',name:site.name,areaServed:site.serviceArea,telephone:site.phone,email:site.email})} />
</head><body>
<header><div class="container"><nav><ul><li><a href="/">Home</a></li><li><a href="/services">Services</a></li><li><a href="/service-areas">Service Areas</a></li><li><a href="/before-after-gallery">Before & After</a></li><li><a href="/blog">Tips</a></li><li><a href="/request-job">Request a Job</a></li></ul></nav></div></header>
<main><slot/></main>
<div class="mobile-stick"><a class="btn btn-secondary" href={`tel:${site.phone}`} data-track="phone_click">Call John</a><a class="btn btn-secondary" href={`sms:${site.sms}`} data-track="sms_click">SMS</a><a class="btn btn-primary" href="/request-job">Request Job</a></div>
<footer><div class="container"><p><strong>{site.name}</strong> · {site.tagline}</p><p>Service area: {site.serviceArea}</p><p>Phone: {site.phone} · Email: {site.email} · ABN: {site.abn}</p><p class="small">Insurance: {site.insurance}</p></div></footer>
</body></html>
