---
import '../styles/global.css';
import TrackingScript from '../components/TrackingScript.astro';
import { site } from '../data/site';
const {title,description} = Astro.props;
---
<html lang="en-AU"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/><title>{title}</title><meta name="description" content={description}/><meta property="og:title" content={title}/><meta property="og:description" content={description}/><meta property="og:type" content="website"/><TrackingScript />
<script type="application/ld+json" set:html={JSON.stringify({'@context':'https://schema.org','@type':'HomeAndConstructionBusiness',name:site.name,areaServed:site.serviceArea,telephone:site.phone,email:site.email})} />
</head><body>
<header class="site-header"><div class="container head-inner"><a href="/" class="brand" aria-label="Wooden Bone home"><span class="brand-mark">🌿</span><span><strong>WOODEN BONE</strong><em>Garden & Landscape</em></span></a><nav class="desktop-nav"><a href="/services">Services</a><a href="/service-areas">Service Areas</a><a href="/before-after-gallery">Before & After</a><a href="/about-john">About John</a><a href="/blog">Tips</a></nav><a class="btn btn-rust head-cta" href="/request-job">Send Photos</a><details class="mobile-nav"><summary>☰</summary><div><a href="/services">Services</a><a href="/service-areas">Service Areas</a><a href="/before-after-gallery">Before & After</a><a href="/about-john">About John</a><a href="/request-job">Request a Quote</a></div></details></div></header>
<main><slot/></main>
<div class="mobile-stick"><a class="btn btn-primary" href={`tel:${site.phone}`} data-track="phone_click">Call</a><a class="btn btn-rust" href={`sms:${site.sms}`} data-track="sms_click">SMS</a><a class="btn btn-ghost" href="/request-job">Request Job</a></div>
<footer class="topo"><div class="container"><p><strong>{site.name}</strong> · {site.tagline}</p><p>Service area: {site.serviceArea}</p><p>Phone: {site.phone} · Email: {site.email} · ABN: {site.abn}</p><p class="small">Insurance: {site.insurance}</p></div></footer>
</body></html>
