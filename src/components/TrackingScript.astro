<script is:inline>
window.dataLayer=window.dataLayer||[];
window.wbgTrack=(event,detail={})=>{window.dataLayer.push({event,...detail});if(window.gtag)window.gtag('event',event,detail)};
document.addEventListener('click',e=>{const el=e.target.closest('[data-track]');if(el)window.wbgTrack(el.dataset.track,{label:el.dataset.label||''});});
document.addEventListener('submit',e=>{if(e.target.matches('[data-track-submit]'))window.wbgTrack('form_submit');});
const io=new IntersectionObserver(entries=>entries.forEach(en=>en.isIntersecting&&en.target.classList.add('in')),{threshold:.15});
document.querySelectorAll('[data-reveal]').forEach(el=>io.observe(el));
</script>
