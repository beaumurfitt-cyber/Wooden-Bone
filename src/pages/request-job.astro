---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Request a Gardening or Landscaping Job | Wooden Bone Garden and Landscape Adelaide" description="Fast local garden and small landscaping estimates.">
<section class="section"><div class="container"><h1>Request a Job</h1><form name="request-job" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thank-you" enctype="multipart/form-data" onfocusin="window.wbgTrack && window.wbgTrack('form_start')" onsubmit="window.wbgTrack && window.wbgTrack('form_submit')"><input type="hidden" name="form-name" value="request-job"/><p hidden><label>Don’t fill this out: <input name="bot-field" /></label></p><div class="form-grid">
<label>Name<input required name="name"/></label><label>Mobile number<input required name="mobile"/></label><label>Email<input type="email" name="email" required/></label><label>Suburb<input name="suburb" required/></label><label class="full">Street address (optional)<input name="address"/></label>
<label class="full">Preferred contact<select name="preferred_contact"><option>Phone</option><option>SMS</option><option>Email</option></select></label>
<fieldset class="full"><legend>Job type</legend><div class="cards">{['Garden maintenance','One-off cleanup','Lawn mowing','Hedge trimming','Weeding','Green waste removal','Irrigation','Turf','Edging','Planting','Garden makeover','Small landscaping','Pre-sale or rental cleanup','Other'].map(i=><label><input type="checkbox" name="job_type" value={i}/> {i}</label>)}</div></fieldset>
<label>Urgency<select name="urgency"><option>This week</option><option>Next 2 weeks</option><option>Flexible</option><option>Urgent</option></select></label>
<label>Recurring<select name="recurring"><option>One-off</option><option>Recurring monthly</option><option>Recurring fortnightly</option><option>Not sure</option></select></label>
<label>Budget<select name="budget"><option>Under $250</option><option>$250–$500</option><option>$500–$1,000</option><option>$1,000+</option><option>Not sure</option></select></label>
<label class="full">Describe the job<textarea name="description" rows="5"></textarea></label>
<label class="full">Upload photos<input type="file" name="photos" multiple onchange="window.wbgTrack&&window.wbgTrack('photo_upload')"/></label>
<label class="full"><input type="checkbox" required name="consent"/> I consent to be contacted about this enquiry.</label>
<button class="btn btn-primary full" type="submit">Request Job Estimate</button></div></form></div></section>
</BaseLayout>
