---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, suburbs, seasonalCampaign } from '../data/site';
const pathways=[['The Garden Reset','Overgrown, tired or hard-to-manage gardens that need a full tidy and reset.','Request a Garden Reset'],['Regular Garden Care','Ongoing mowing, edging, weeding and seasonal care to keep it under control.','Ask about regular care'],['Lawn, Edges & Turf','Cleaner lines, better street appeal and stronger lawns.','Sort the lawn'],['Irrigation & Summer Prep','Fixes and prep work to help gardens survive Adelaide heat.','Prepare for summer'],['Small Landscape Improvements','Practical upgrades without hiring a big landscaping company.','Plan a small upgrade'],['Pre-Sale Garden Tidy','Fast outside tidy for inspections, photos and handovers.','Get sale-ready']];
---
<BaseLayout title="Wooden Bone Garden and Landscape | Local Gardener & Landscaper Bellevue Heights" description="From overgrown to under control across Adelaide's southern suburbs.">
<section class="hero"><div class="container grid two"><div><span class="badge">Local Bellevue Heights operator</span><h1>{site.campaign}</h1><p>{site.tagline}</p><p>Garden cleanups, maintenance, irrigation, turf, edging, planting and small landscape improvements for homes across Adelaide’s southern suburbs.</p><p><a class="btn btn-primary" href="/request-job">Request a Job</a> <a class="btn btn-secondary" href="/request-job" data-track="sms_click">Send Photos for a Quick Estimate</a></p><p class="badge">Small jobs welcome · One-off and recurring work · Southern Adelaide suburbs</p></div><div class="card"><img src="/images/gallery/placeholder.svg" alt="Placeholder transformation image" loading="lazy"/><p class="small">Placeholder image — replace with real garden transformation photos.</p></div></div></section>
<section class="section"><div class="container"><h2>What needs sorting?</h2><div class="cards">{['Overgrown yard?','Patchy lawn?','Messy garden beds?','Irrigation not coping?','Selling soon?','No time to keep up?','Edges looking rough?','Garden got away from you?'].map(i=><a class="card" href="/request-job">{i}</a>)}</div></div></section>
<section class="section"><div class="container"><h2>Choose the kind of garden reset you need.</h2><div class="cards">{pathways.map(p=><article class="card"><h3>{p[0]}</h3><p>{p[1]}</p><a href="/request-job" data-track="service_page_cta_click">{p[2]}</a></article>)}</div></div></section>
<section class="section"><div class="container"><h2>Small changes. Big difference.</h2><div class="cards">{['Bellevue Heights','Blackwood'].map(s=><article class="card"><p><strong>{s}</strong> · Cleanup + edging</p><img src="/images/gallery/placeholder.svg" alt="Before and after placeholder" loading="lazy"/><p>Before / After placeholders — replace with real project photos.</p><a href="/request-job" data-track="gallery_cta_click">Request a similar job</a></article>)}</div></div></section>
<section class="section"><div class="container"><h2>Built for Adelaide’s southern gardens.</h2><p>Dry summers, sloping blocks, established plantings, gum leaf build-up, tired beds and patchy lawns are common across foothills suburbs.</p><p>{suburbs.slice(0,11).join(' · ')}</p><a class="btn btn-ghost" href="/service-areas">See service areas</a></div></section>
<section class="section"><div class="container"><h2>Meet John — the person doing the work.</h2><p>When you contact Wooden Bone Garden and Landscape, you deal directly with John. No fuss. Clear communication. Work done properly.</p><a href="/about-john" class="btn btn-ghost">Ask John about your garden</a></div></section>
<section class="section"><div class="container card"><h2>{seasonalCampaign.title}</h2><p>{seasonalCampaign.text}</p><a class="btn btn-secondary" data-track="seasonal_cta_click" href="/request-job">{seasonalCampaign.cta}</a></div></section>
<section class="section"><div class="container"><h2>Ready to bring the garden back?</h2><p>Send a few photos, describe what needs doing, and John will help with the next step.</p><p><a class="btn btn-primary" href="/request-job">Request a Job</a> <a class="btn btn-secondary" href={`tel:${site.phone}`} data-track="phone_click">Call John</a> <a class="btn btn-ghost" href={`sms:${site.sms}`} data-track="sms_click">Send Photos</a></p></div></section>
</BaseLayout>
