---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, suburbs } from '../data/site';
const problems=[['🍃','Overgrown yard?'],['🌱','Patchy lawn?'],['🪴','Messy beds?'],['💧','Irrigation not coping?'],['🏠','Selling soon?'],['⏱','No time to keep up?'],['📏','Edges looking rough?'],['🧹','Garden got away from you?']];
---
<BaseLayout title="Wooden Bone Garden and Landscape | Local Gardener & Landscaper Bellevue Heights" description="From overgrown to under control across Adelaide's southern suburbs.">
<section class="hero"><div class="container"><div class="hero-card"><span class="badge">Local Bellevue Heights Operator</span><h1>From overgrown to under control.</h1><p><strong>Garden work with backbone.</strong></p><p>Garden cleanups, maintenance, irrigation, turf, edging, planting and small landscape improvements for homes across Adelaide’s southern suburbs.</p><p><a class="btn btn-primary" href="/request-job">Request a Job</a> <a class="btn btn-rust" href="/request-job" data-track="sms_click">Send Photos for a Quick Estimate</a></p><p><span class="badge">Small Jobs Welcome</span><span class="badge">One-Off & Recurring Work</span><span class="badge">Direct With John</span></p></div></div></section>
<div class="band"></div>
<section class="section topo"><div class="container"><h2>What needs sorting right now?</h2><div class="cards">{problems.map(p=><a class="problem" href="/request-job"><span class="icon-dot">{p[0]}</span><span>{p[1]}</span></a>)}</div></div></section>
<section class="section"><div class="container"><h2>Built for Adelaide’s southern gardens.</h2><p>Dry summers, sloping blocks, leaf litter, tired beds and patchy lawns are common across foothills suburbs.</p><p>{suburbs.slice(0,11).join(' · ')}</p><p><a class="btn btn-ghost" href="/service-areas">See service areas</a></p></div></section>
<section class="section"><div class="container tag"><h2>Ready to bring the garden back?</h2><p>Send a few photos, describe what needs doing, and John will help with the next step.</p><p><a class="btn btn-primary" href="/request-job">Request a Job</a> <a class="btn btn-rust" href={`tel:${site.phone}`} data-track="phone_click">Call John</a></p></div></section>
</BaseLayout>
