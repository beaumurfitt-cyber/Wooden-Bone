---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
const problems=[['🪴','The yard’s gone feral'],['🌱','Lawn looking sad'],['🌾','Beds full of weeds'],['📏','Edges disappeared'],['💧','Irrigation not coping'],['🏡','Selling soon'],['⏰','No time to keep up'],['✨','Need a fresh start']];
const pathways=[
['🧹','The Garden Rescue','For gardens that have got away from you.',['Cleanup','Weeding','Green waste'],'Rescue my garden'],
['🗓️','The Regular Keep-It-Tidy','Ongoing care so it does not get out of hand again.',['Mowing','Edging','Seasonal tidy'],'Ask about regular care'],
['📐','Lawn, Edges & Street Appeal','Clean lines, tidy edges and a better first impression.',['Lawn tidy','Hard edges','Street frontage'],'Lift street appeal'],
['☀️','Irrigation & Summer Survival','Help the garden cope before Adelaide heat arrives.',['Checks','Fixes','Efficiency'],'Prep for summer'],
['🪵','Small Landscape Upgrades','Practical improvements without the big-landscaper price tag.',['Beds','Planting','Mulch'],'Plan an upgrade'],
['📸','Pre-Sale Garden Polish','Make the outside look cared for before photos and inspections.',['Fast tidy','Waste removal','Presentation'],'Get sale-ready']
];
---
<BaseLayout title="Wooden Bone Garden and Landscape | Local Gardener & Landscaper Bellevue Heights" description="Garden rescue with personality across Adelaide's southern suburbs.">
<section class="campaign-hero topo"><div class="hero-split">
  <div class="hero-half before"><img src="/images/gallery/placeholder.svg" alt="Before garden with overgrown lawn and messy beds" loading="eager"/><span class="sticker">Jungle mode</span><span class="chip">Before</span></div>
  <div class="hero-half after"><img src="/images/gallery/placeholder.svg" alt="After garden with tidy edges and fresh mulch" loading="eager"/><span class="sticker good">Weekend-ready</span><span class="chip">Back under control</span></div>
</div>
<div class="container hero-overlay"><div class="hero-panel"><span class="badge">Garden rescue with personality</span><h1>From jungle to joy.</h1><p class="lead">Garden cleanups, maintenance and small landscape improvements for Adelaide homes that need a reset.</p><p class="support">Garden work with backbone. <span class="small-note">From overgrown to under control.</span></p><p><a class="btn btn-rust" href="/request-job" data-track="sms_click">Send Photos for a Quick Estimate</a> <a class="btn btn-primary" href="/request-job">Request a Job</a></p><p><span class="badge">Local Bellevue Heights Operator</span><span class="badge">Fair, Practical Pricing</span><span class="badge">Small Jobs Welcome</span><span class="badge">Direct With John</span></p></div></div>
</section>
<div class="band"></div>
<section class="section"><div class="container"><h2>What needs rescuing?</h2><div class="cards">{problems.map(p=><a class="problem" href="/request-job"><span class="icon-dot">{p[0]}</span><span>{p[1]}</span></a>)}</div></div></section>
<section class="section topo"><div class="container"><h2>Choose your rescue pathway.</h2><div class="cards pathways">{pathways.map(p=><article class="path-card"><div class="path-head"><span class="path-icon">{p[0]}</span><h3>{p[1]}</h3></div><p>{p[2]}</p><ul>{p[3].map(t=><li>{t}</li>)}</ul><a href="/request-job" data-track="service_page_cta_click">{p[4]} →</a></article>)}</div></div></section>
<section class="section"><div class="container quote-cta"><h2>Show John the jungle.</h2><p>Upload a few photos, pick what needs doing, and John will help work out the next step. No big-company runaround. Just practical garden help.</p><p><a class="btn btn-rust" href="/request-job">Send my garden rescue request</a></p></div></section>
<section class="section"><div class="container about-preview"><div><h2>Local, direct and fair.</h2><p>When you contact Wooden Bone, you’re dealing with John — the person doing the work.</p><p><span class="badge">Direct with John</span><span class="badge">No franchise runaround</span><span class="badge">Practical advice</span></p><a class="btn btn-primary" href="/about-john">Ask John about your garden</a></div><div class="about-images"><img src="/images/gallery/placeholder.svg" alt="Portrait placeholder for John" loading="lazy"/><img src="/images/gallery/placeholder.svg" alt="Work photo placeholder with tools and wheelbarrow" loading="lazy"/></div></div></section>
</BaseLayout>
