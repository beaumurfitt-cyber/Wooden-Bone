---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, suburbs, seasonalCampaign } from '../data/site';
const pathways=[
['🧹','The Garden Reset','For overgrown spaces that need a proper rescue.',['Weeding','Pruning','Green waste','Bed recovery'],'Request a Garden Reset'],
['🌿','Regular Garden Care','Ongoing support to keep it under control.',['Mowing','Edging','Weeding','Seasonal upkeep'],'Ask about regular care'],
['🌱','Lawn, Edges & Turf','Sharper lines and healthier lawn areas.',['Mowing','Edging','Turf prep','Turf installs'],'Sort the lawn'],
['💧','Irrigation & Summer Prep','Practical water setup for Adelaide heat.',['Checks','Sprinkler fixes','Drippers','Mulch prep'],'Prepare for summer'],
['🪵','Small Landscape Improvements','High-impact upgrades without big build overhead.',['Edging','Beds','Planting','Soil prep'],'Plan a small upgrade'],
['🏡','Pre-Sale Garden Tidy','Presentation-focused tidy for listings and handover.',['Quick tidy','Edges','Weeding','Street appeal'],'Get sale-ready']
];
---
<BaseLayout title="Wooden Bone Garden and Landscape | Local Gardener & Landscaper Bellevue Heights" description="From overgrown to under control across Adelaide's southern suburbs.">
<section class="hero topo"><div class="container two"><div><span class="badge dark">Local Bellevue Heights Operator</span><h1>{site.campaign}</h1><p><strong>{site.tagline}</strong></p><p>Garden cleanups, maintenance, irrigation, turf, edging, planting and small landscape improvements for homes across Adelaide’s southern suburbs.</p><p><a class="btn btn-primary" href="/request-job">Request a Job</a> <a class="btn btn-rust" href="/request-job" data-track="sms_click">Send Photos for a Quick Estimate</a></p><p><span class="badge">Small Jobs Welcome</span><span class="badge">One-Off & Recurring Work</span><span class="badge">Direct With John</span><span class="badge">Southern Adelaide Suburbs</span></p></div><div class="collage"><img src="/images/gallery/placeholder.svg" alt="Garden path and foothills style placeholder" loading="eager"/><img src="/images/gallery/placeholder.svg" alt="Garden transformation placeholder" loading="lazy"/><img src="/images/gallery/placeholder.svg" alt="Tools and garden work placeholder" loading="lazy"/></div></div></section>
<section class="section"><div class="container"><h2>What needs sorting right now?</h2><div class="cards">{['Overgrown yard?','Patchy lawn?','Messy beds?','Irrigation not coping?','Selling soon?','No time to keep up?','Edges looking rough?','Garden got away from you?'].map(i=><a class="tag" href="/request-job">{i}</a>)}</div></div></section>
<section class="section topo"><div class="container"><h2>Choose your garden reset pathway.</h2><div class="cards">{pathways.map(p=><article class="tag"><div class="icon">{p[0]}</div><h3>{p[1]}</h3><p>{p[2]}</p><ul>{p[3].map(w=><li>{w}</li>)}</ul><a data-track="service_page_cta_click" href="/request-job">{p[4]}</a></article>)}</div></div></section>
<section class="section"><div class="container"><h2>Small changes. Big difference. (Before → After)</h2><p>Placeholder case studies until real project photos are supplied.</p><a class="btn btn-ghost" href="/before-after-gallery">See recent work</a></div></section>
<section class="section topo"><div class="container"><h2>Built for Adelaide’s southern gardens.</h2><p>Dry summers, sloping blocks, leaf litter, tired beds and patchy lawns are common in foothills suburbs.</p><p>{suburbs.slice(0,11).join(' · ')}</p><a class="btn btn-ghost" href="/service-areas">See service areas</a></div></section>
<section class="section"><div class="container card"><h2>{seasonalCampaign.title}</h2><p>{seasonalCampaign.text}</p><a class="btn btn-rust" data-track="seasonal_cta_click" href="/request-job">{seasonalCampaign.cta}</a></div></section>
</BaseLayout>
