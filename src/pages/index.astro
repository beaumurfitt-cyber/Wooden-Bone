---
import BaseLayout from '../layouts/BaseLayout.astro';
const services=[
['Garden Tidy-Ups & Makeovers','Visible tidy-ups and practical resets for overgrown gardens.','/images/home/service-tidy.svg'],
['Garden Maintenance','Regular care to keep lawns, beds and hedges manageable.','/images/home/service-lawn.svg'],
['Lawn, Edges & Turf','Cleaner lines, better street appeal and healthier lawn areas.','/images/home/service-lawn.svg'],
['Irrigation & Summer Prep','Simple irrigation checks and fixes before Adelaide heat.','/images/home/service-planting.svg'],
['Small Landscape Improvements','Practical upgrades without a big-landscaper price tag.','/images/home/service-planting.svg'],
['Green Waste / Rubbish Removal','Clean finish with practical removal support where needed.','/images/home/service-tidy.svg']
];
const suburbs=['Bellevue Heights','Blackwood','Belair','Eden Hills','Flagstaff Hill','Aberfoyle Park','Coromandel Valley','Hawthorndene','Mitcham','Pasadena','Panorama'];
---
<BaseLayout title="Wooden Bone Garden and Landscape | Adelaide Garden Tidy-ups and Makeovers" description="Garden makeovers, tidy-ups and maintenance without the runaround.">
<section class="hero-real"><img src="/images/home/hero-garden.svg" alt="Tidy suburban garden with lawn, mulch and garden beds" /><div class="hero-overlay2"><div class="container"><div class="hero-copy"><h1>Garden makeovers, tidy-ups and maintenance without the runaround.</h1><p>Wooden Bone Garden & Landscape helps Adelaide homeowners turn overgrown, tired or hard-to-manage gardens into clean, usable outdoor spaces.</p><p><strong>Local to Bellevue Heights. Fair, practical and direct with John.</strong></p><p><a class="btn btn-primary" href="/request-job">Request a Quote</a> <a class="btn btn-rust" href="/request-job" data-track="sms_click">Send Photos</a></p><p><span class="badge">Garden tidy-ups</span><span class="badge">Small makeovers</span><span class="badge">Regular maintenance</span><span class="badge">Local southern suburbs</span><span class="badge">Direct with John</span></p></div></div></div></section>
<section class="promise-strip"><div class="container promise-grid"><div>Tidy-ups that make a visible difference</div><div>Practical makeovers without the big-landscaper price tag</div><div>Regular care to keep things under control</div></div></section>
<section class="section"><div class="container"><h2>Services</h2><div class="cards svc">{services.map(s=><article class="svc-card"><img src={s[2]} alt={s[0]} loading="lazy"/><div><h3>{s[0]}</h3><p>{s[1]}</p><a href="/request-job" data-track="service_page_cta_click">Request a quote →</a></div></article>)}</div></div></section>
<section class="section"><div class="container"><h2>Recent project style</h2><div class="cards"><article class="svc-card"><img src="/images/home/project-1.svg" alt="Neat garden bed and lawn edge" loading="lazy"/><div><h3>Yard cleanup and edge reset</h3><p>Practical tidy-up for a more usable and presentable backyard.</p><a href="/request-job" data-track="gallery_cta_click">Request similar work →</a></div></article><article class="svc-card"><img src="/images/home/project-2.svg" alt="Fresh mulch and tidy planting" loading="lazy"/><div><h3>Mulch and planting refresh</h3><p>Simple changes that improve look and reduce maintenance pressure.</p><a href="/request-job" data-track="gallery_cta_click">Request similar work →</a></div></article></div></div></section>
<section class="section"><div class="container quote-cta"><h2>Request a Quote</h2><form name="quick-quote" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thank-you" enctype="multipart/form-data"><input type="hidden" name="form-name" value="quick-quote"/><p hidden><input name="bot-field"/></p><div class="qgrid"><input name="name" placeholder="Name" required/><input name="phone" placeholder="Phone" required/><input name="email" placeholder="Email" type="email" required/><input name="suburb" placeholder="Suburb" required/><input name="service" placeholder="Service required"/><textarea name="message" placeholder="Tell us what needs doing"></textarea><input type="file" name="photos" multiple/><button class="btn btn-rust" type="submit">Request a Quote</button></div></form></div></section>
<section class="section"><div class="container"><h2>Why choose Wooden Bone</h2><div class="cards"><div class="problem">Direct with John</div><div class="problem">Practical advice</div><div class="problem">Fair pricing</div><div class="problem">Small jobs welcome</div><div class="problem">Local southern suburbs</div><div class="problem">Reliable scheduling</div></div></div></section>
<section class="section"><div class="container about-preview"><div><h2>Meet John</h2><p>When you contact Wooden Bone, you’re dealing directly with John — practical advice, clear communication and work done properly.</p><a class="btn btn-primary" href="/about-john">Ask John about your garden</a></div><div class="about-images"><img src="/images/home/john.svg" alt="Garden operator at work" loading="lazy"/></div></div></section>
<section class="section"><div class="container"><h2>Service areas</h2><p>{suburbs.map(s=><span class="badge">{s}</span>)}</p></div></section>
<section class="section"><div class="container quote-cta"><h2>Ready to get the garden back under control?</h2><p><a class="btn btn-primary" href="/request-job">Request a Quote</a> <a class="btn btn-rust" href="/request-job" data-track="sms_click">Send Photos</a></p></div></section>
</BaseLayout>
