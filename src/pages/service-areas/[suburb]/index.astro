---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { suburbs } from '../../../data/site';
const profile={
'bellevue-heights':'sloping blocks and established gardens','blackwood':'leaf litter and mixed native/exotic planting','belair':'larger blocks and tree canopy debris','eden-hills':'hillside watering and access challenges','flagstaff-hill':'family yards and lawn wear','aberfoyle-park':'summer watering pressure and patchy lawns','coromandel-valley':'tree litter and seasonal overgrowth','hawthorndene':'older gardens needing practical resets','mitcham':'presentation-focused tidy-ups and edging','pasadena':'compact blocks and low-maintenance upgrades','panorama':'front-yard presentation and irrigation checks'};
export async function getStaticPaths(){return ['Bellevue Heights','Blackwood','Belair','Eden Hills','Flagstaff Hill','Aberfoyle Park','Coromandel Valley','Hawthorndene','Mitcham','Pasadena','Panorama'].map(s=>({params:{suburb:s.toLowerCase().replace(/\s+/g,'-')},props:{suburb:s}}));}
const {suburb}=Astro.props; const slug=suburb.toLowerCase().replace(/\s+/g,'-');
const nearby=suburbs.filter(s=>s!==suburb).slice(0,5);
---
<BaseLayout title={`Gardening and Landscaping Services in ${suburb}`} description={`Local gardening and small landscaping in ${suburb}, Adelaide southern suburbs.`}><section class="section"><div class="container"><h1>Gardening and Landscaping Services in {suburb}</h1><p>Wooden Bone provides practical garden and small landscape help in {suburb} and surrounding southern Adelaide suburbs, with direct contact to John.</p><p>Common local needs in {suburb}: {profile[slug] || 'summer garden control, tidy-ups and practical improvements'}.</p><h2>Services in {suburb}</h2><ul><li>Garden cleanups and maintenance</li><li>Lawn mowing, edging and turf improvements</li><li>Irrigation checks and fixes</li><li>Pre-sale tidy-ups and small landscaping</li></ul><h2>FAQs</h2><p><strong>Can I send photos for a quote?</strong> Yes. Photo-based enquiries help speed up the next step.</p><p><strong>Are small jobs welcome?</strong> Yes — small jobs, one-off work and recurring care are all welcome.</p><p><a class="btn btn-primary" data-track="suburb_page_cta_click" href="/request-job">Request a Job</a></p><h3>Nearby suburbs</h3><p>{nearby.map(n=><a class="badge" href={`/service-areas/${n.toLowerCase().replace(/\s+/g,'-')}`}>{n}</a>)}</p></div></section>
<script type="application/ld+json" set:html={JSON.stringify({'@context':'https://schema.org','@type':'FAQPage',mainEntity:[{'@type':'Question',name:'Can I send photos for a quote?',acceptedAnswer:{'@type':'Answer',text:'Yes. Photo-based enquiries help speed up the next step.'}},{'@type':'Question',name:'Are small jobs welcome?',acceptedAnswer:{'@type':'Answer',text:'Yes — small jobs, one-off work and recurring care are all welcome.'}}]})} />
</BaseLayout>
