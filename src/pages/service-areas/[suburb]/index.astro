---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { suburbs } from '../../../data/site';
export async function getStaticPaths(){return suburbs.map(s=>({params:{suburb:s.toLowerCase().replace(/\s+/g,'-')},props:{suburb:s}}));}
const { suburb } = Astro.props;
const nearby = suburbs.filter(s=>s!==suburb).slice(0,4);
---
<BaseLayout title={`Gardening and Landscaping Services in ${suburb}`} description={`Local gardening and small landscaping in ${suburb}.`}>
<section class="section"><div class="container"><h1>Gardening and Landscaping Services in {suburb}</h1><p>Local intro for {suburb}, focused on reliable, practical outcomes and simple quoting.</p><h2>Common local garden needs</h2><ul><li>Overgrown yards</li><li>Irrigation fixes</li><li>Edging and tidy-ups</li></ul><h2>FAQs</h2><p><strong>Can I send photos?</strong> Yes, photo-based estimates are welcome.</p><p><strong>Do you do small jobs?</strong> Yes, small jobs welcome.</p><a href="/request-job" data-track="suburb_page_cta_click" class="btn btn-primary">Request a Job</a><h3>Nearby suburbs</h3><ul>{nearby.map(n=><li><a href={`/service-areas/${n.toLowerCase().replace(/\s+/g,'-')}`}>{n}</a></li>)}</ul></div></section>
<script type="application/ld+json" set:html={JSON.stringify({'@context':'https://schema.org','@type':'FAQPage',mainEntity:[{'@type':'Question',name:'Can I send photos?',acceptedAnswer:{'@type':'Answer',text:'Yes, photo-based estimates are welcome.'}}]})} />
</BaseLayout>
